generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model discoveries {
  id             Int     @id @default(autoincrement())
  island_id      Int
  discoverer     String  @db.VarChar(255)
  discovery_year Int?
  notes          String? @db.Text
  islands        islands @relation(fields: [island_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "discoveries_ibfk_1")

  @@index([island_id], map: "island_id")
}

model islands {
  id               Int           @id @default(autoincrement())
  name             String        @unique(map: "name") @db.VarChar(255)
  latitude         Decimal       @db.Decimal(9, 6)
  longitude        Decimal       @db.Decimal(9, 6)
  description      String?       @db.Text
  discovery_date   DateTime?     @db.Date
  disappeared_date DateTime?     @db.Date
  discoveries      discoveries[]
  media            media[]
  references        reference[]
}

model media {
  id          Int              @id @default(autoincrement())
  island_id   Int
  media_type  media_media_type
  media_url   String           @db.VarChar(500)
  description String?          @db.Text
  islands     islands          @relation(fields: [island_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "media_ibfk_1")

  @@index([island_id], map: "island_id")
}

model reference {
  id          Int     @id @default(autoincrement())
  island_id   Int
  source_name String  @db.VarChar(255)
  source_url  String  @db.VarChar(500)
  description String? @db.Text
  islands     islands @relation(fields: [island_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "reference_ibfk_1")

  @@index([island_id], map: "island_id")
}

enum media_media_type {
  image
  video
  document
}
